# Duke AI Gateway (LiteLLM)
DUKE_AI_API_KEY=your_litellm_token_here
DUKE_AI_MODEL=GPT 4.1 Mini

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Cron job security (Vercel Cron sends this as Authorization: Bearer …)
CRON_SECRET=your_random_secret_here

# Settings storage — Upstash Redis (free tier)
# Create at https://upstash.com and connect on Vercel
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternative: single-user env-based config (no Redis needed)
# PHONE_NUMBER=+15551234567
# INTERESTS=news,islamic
# DELIVERY_TIME=07:00
# TIMEZONE=America/New_York
